	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"var xsrfCookie = pm.cookies.get('XSRF-TOKEN');",
					"console.log('DEBUG: XSRF Cookie found: ', xsrfCookie ? 'YES' : 'NO', xsrfCookie);",
					"if (xsrfCookie) {",
					"    pm.request.headers.add({",
					"        key: 'X-XSRF-TOKEN',",
					"        value: xsrfCookie",
					"    });",
					"    console.log('DEBUG: Added X-XSRF-TOKEN header');",
					"}"
				]
			}
		}
	],
