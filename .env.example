# ==========================================
# ENVIRONMENT TEMPLATE — safe to commit
# ==========================================
# Sao chép file này thành `.env` (dev) hoặc `.env.prod` (production) rồi điền giá trị thật.
# Các file `.env*` khác đã được gitignore — chỉ file `.env.example` này được commit.

# --- Profile ---
# dev | prod . Bỏ trống hoặc "dev" để seed teacher demo và cho phép password admin mặc định.
SPRING_PROFILES_ACTIVE=dev

# --- Domain ---
DOMAIN_NAME=localhost

# --- Database (MySQL) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=warehouse_db
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_NAME=warehouse-bucket
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- Application ---
APP_PORT=8080
# Sinh JWT secret mạnh (chọn 1):
#   jshell : System.out.println(java.util.Base64.getEncoder().encodeToString(java.security.SecureRandom.getInstanceStrong().generateSeed(48)))
#   node   : node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   openssl: openssl rand -base64 48
JWT_SECRET=replace-with-strong-256-bit-secret
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# --- Admin seed account ---
# Dev : có thể để trống, sẽ dùng mặc định 'admin123' (app log WARN).
# Prod: BẮT BUỘC set khác 'admin123'. Nếu vẫn là mặc định khi profile=prod → app crash khi boot.
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@kindergarten.com
APP_ADMIN_PASSWORD=replace-with-strong-password

# --- Mail (SMTP) ---
# Gmail: dùng "App Password" (https://myaccount.google.com/apppasswords), KHÔNG dùng mật khẩu thật.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Rollbar (error tracking, optional) ---
ROLLBAR_ACCESS_TOKEN=
ROLLBAR_ENABLED=false
ROLLBAR_ENV=development

# --- Cookie ---
# Dev  HTTP : secure=false, same-site=Lax
# Prod HTTPS: secure=true , same-site=None (FE khác domain) hoặc Strict (cùng domain)
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# --- External APIs (optional) ---
YOUTUBE_API_KEY=
