# ==========================================
# ENVIRONMENT VARIABLES (Production & Dev)
# Copy this file to .env and fill in your values
# ==========================================

# --- Domain Configuration ---
# Used for Nginx config and MinIO redirect
DOMAIN_NAME=your-domain.com

# --- Database Configuration (MySQL) ---
# These variables are used by both MySQL Container and Spring Boot
MYSQL_HOST=mysql
MYSQL_ROOT_PASSWORD=ChangeThisToStrongPassword123!
MYSQL_DATABASE=warehouse_db
MYSQL_USER=warehouse_user
MYSQL_PASSWORD=ChangeThisToStrongUserPassword123!

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PASSWORD=ChangeThisToStrongRedisPassword123!

# --- MinIO Configuration (S3 Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeThisToStrongMinioPassword123!
MINIO_BUCKET_NAME=resources

# --- Application Configuration ---
# Port exposed to Host (Nginx will proxy to this)
APP_PORT=8080

# Security
JWT_SECRET=ChangeThisToAVeryLongSecretKeyForSecurityReasons1234567890
JWT_EXPIRATION=86400000

# CORS (Frontend Domain)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com,http://localhost:4200

# Rollbar (Optional - Error Tracking)
ROLLBAR_ACCESS_TOKEN=
ROLLBAR_ENABLED=true
ROLLBAR_ENV=production
